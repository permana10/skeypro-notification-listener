<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main"
    android:padding="20dp">

    <!-- Header -->
<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_centerHorizontal="true"
    android:orientation="horizontal"
    android:gravity="center_vertical">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKEY"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOX"
            android:textColor="@color/primary_green"
            android:textSize="36sp"
            android:textStyle="bold"/>

    </LinearLayout>

<FrameLayout
    android:layout_width="36dp"
    android:layout_height="36dp"
    android:layout_alignParentEnd="true"
    android:layout_centerVertical="true">

    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:tint="@color/text_secondary"/>

    <View
        android:id="@+id/viewBadge"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_gravity="end|top"
        android:visibility="gone"
        android:background="@drawable/bg_badge_red"/>

</FrameLayout>

</RelativeLayout>

    <!-- Device ID -->
    <TextView
    android:id="@+id/txtDeviceId"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="18dp"
    android:text="ID : Belum Terdaftar"
    android:textColor="@color/text_secondary"
    android:textSize="16sp"
    android:includeFontPadding="false" />

    <!-- Status Koneksi -->
    <TextView
        android:id="@+id/txtConnection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="0dp"
        android:paddingLeft="12dp"
        android:paddingTop="0dp"
        android:paddingRight="12dp"
        android:paddingBottom="0dp"
        android:text="● Connected"
        android:textColor="@color/status_connected"
        android:textSize="15sp"
        android:textStyle="bold"
    android:includeFontPadding="false" />

    <!-- Input Device ID -->
    <EditText
        android:id="@+id/edtDeviceId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/primary_green"
        android:hint="Contoh : SBX-D77A4FF9"
        android:inputType="textCapCharacters"
        android:padding="10dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <TextView
        android:id="@+id/txtDeviceHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Masukkan Device ID yang tampil pada Soundbox"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <!-- Tombol -->
    <Button
    android:id="@+id/btnPilihQris"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="16dp"
    android:background="@drawable/bg_button_outline"
    android:text="PILIH QRIS"
    android:textAllCaps="false"
    android:textColor="@color/text_secondary"
    android:textStyle="bold"/>

    <Button
    android:id="@+id/btnDaftar"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_button_secondary"
    android:text="DAFTARKAN"
    android:textAllCaps="false"
    android:textColor="@color/white"
    android:textStyle="bold"/>

<!-- Preview QRIS + Informasi Merchant -->
<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="10dp"
    android:orientation="vertical"
    android:background="@drawable/bg_qris"
    android:paddingHorizontal="3dp"
    android:paddingVertical="3dp">

    <ImageView
    android:id="@+id/imgQris"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:maxHeight="480dp"
    android:adjustViewBounds="true"
    android:scaleType="centerInside"/>

    <ProgressBar
        android:id="@+id/progressRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>

</LinearLayout>

<LinearLayout
    android:id="@+id/layoutWelcome"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="70dp"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SKEYBOX QRIS UNIVERSAL"
        android:textStyle="bold"
        android:textSize="16sp"
        android:gravity="center"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Menerima notifikasi pembayaran QRIS secara real-time langsung ke perangkat Soundbox Anda."
        android:textSize="13sp"
        android:gravity="center"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="◾ Mendukung berbagai aplikasi pembayaran QRIS"
        android:textStyle="bold"
        android:textSize="12sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="◾ Monitoring saldo otomatis"
        android:textStyle="bold"
        android:textSize="12sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="◾ Cocok untuk UMKM, toko, warung dan usaha rumahan" 
        android:textStyle="bold"
        android:textSize="12sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Masukkan Device ID dan upload QRIS untuk mulai menggunakan SKEYBOX."
        android:textSize="13sp"
        android:gravity="center"/>

</LinearLayout>

<LinearLayout
    android:id="@+id/layoutMerchantInfo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="10dp">

    <TextView
        android:id="@+id/txtMerchant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Merchant : -"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="15sp"/>

    <TextView
        android:id="@+id/txtProvider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:text="Provider : -"
        android:textColor="@color/text_primary"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:text="Status : -"
        android:textColor="@color/status_connected"
        android:textStyle="bold"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="SALDO QRIS"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/txtSaldo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Rp 0"
        android:textColor="@color/primary_green"
        android:textStyle="bold"
        android:textSize="26sp"/>

</LinearLayout>

    <View
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"/>

    <!-- Footer -->
    <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="15dp"
    android:layout_marginBottom="0dp"
    android:orientation="horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Powered by "
        android:textColor="@color/text_secondary"
        android:textSize="10sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SKEYPRO.ID"
        android:textColor="@color/primary_green"
        android:textStyle="bold"
        android:textSize="10sp"/>

</LinearLayout>
</LinearLayout>

